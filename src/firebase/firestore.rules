rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return signedIn() && profile().role == role;
    }

    function commandAccess() {
      return hasRole('admin') || hasRole('commander');
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if request.auth.uid == userId || commandAccess();
      allow delete: if hasRole('admin');
    }

    match /incidents/{incidentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if commandAccess() || hasRole('officer');
      allow delete: if hasRole('admin');
    }

    match /alerts/{alertId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if commandAccess();
    }

    match /sectors/{sectorId} {
      allow read: if signedIn();
      allow write: if commandAccess();
    }

    match /cameras/{cameraId} {
      allow read: if signedIn();
      allow write: if commandAccess();
    }

    match /activityLogs/{logId} {
      allow read: if commandAccess();
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /officerResponses/{responseId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if commandAccess();
    }
  }
}
